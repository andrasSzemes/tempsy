generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(uuid())
  cognitoSub  String   @unique
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
}