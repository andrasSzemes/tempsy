    ('se figurer', 'je', 'je me suis figuré'),
    ('se figurer', 'tu', 'tu t’es figuré'),
    ('se figurer', 'il', 'il s’est figuré'),
    ('se figurer', 'elle', 'elle s’est figurée'),
    ('se figurer', 'on', 'on s’est figuré'),
    ('se figurer', 'nous', 'nous nous sommes figurés'),
    ('se figurer', 'vous', 'vous vous êtes figurés'),
    ('se figurer', 'ils', 'ils se sont figurés'),
    ('se figurer', 'elles', 'elles se sont figurées')
) AS c("verb_name", "subject_name", "text")
JOIN "Verb" v ON v."name" = c."verb_name"
JOIN "Subject" s ON s."name" = c."subject_name"
JOIN "Tense" t ON t."name" = 'Passé Composé'
ON CONFLICT ("verb_id", "subject_id", "tense_id")
DO UPDATE SET "text" = EXCLUDED."text";
